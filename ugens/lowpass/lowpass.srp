def lowpass(input, cutoff, optional chans):
    chans = max_chans(chans, input, cutoff)
    Ugen(new_ugen_id(), "lowpass", chans, 'a', "UU", 'input', input, "a",
         'cutoff', cutoff, "abc")

def lowpassb(input, cutoff, optional chans):
    chans = max_chans(chans, input, cutoff)
    Ugen(new_ugen_id(), "lowpassb", chans, 'b', "UU", 'input', input, "bc",
         'cutoff', cutoff, "bc")

