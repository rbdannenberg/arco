TRANSPOSITIONS = [-24, -19, -12, -11, -10, -9, -8, -7, -5, -4, -3, -2,
                    2,   3,   4,   5,   7, 12]
TRANS_WEIGHTS =  [ 10,   5,  15,   8,   6,  7,  7,  4,  4,  7,  8,  4,
                    4,   5,   5,   7,   7,  9]

actual_state = nil


class Autofx_ctrl:
    var statemgr
    var states
    var states2
    var play_id
    var waiting
    var stop_waiting  // set to true when waiting and gap_detected

