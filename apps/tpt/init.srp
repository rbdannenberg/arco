def save_data(id, rest data):
# save a row to data_file (a .csv file). Row contains time, id, and data.
# The fast way shown here to build a string is to make an array of strings
# and flatten it. It saves copying the string so far to append something.
    if not data_file:
        if SAVE_DATA:
            display "save_data", id, data
        return
    var row = [str(o2_time_get()), ",", id]
    for d in data:
        row.append(",")
        row.append(str(d))
    row.append("\n")
    data_file.write(flatten(row))


data_file = nil
data_file_id = 1


def start_poll_test():
    sched_select(rtsched)
    sched_cause(0.002, nil, 'poll_callback')
    poll_last_time = sched_time_get()
    poll_count = 0
    poll_short_count = 0
    poll_long_count = 0
    poll_shortest = 1.0
    poll_longest = 0


def poll_callback():
    var now = sched_time_get()
    var delay = now - poll_last_time
    if delay < 0.001:
        poll_short_count = poll_short_count + 1
    elif delay > 0.005:
        poll_long_count = poll_long_count + 1
    if data_file:
        print "delay", delay
    poll_count = poll_count + 1
    poll_shortest = min(poll_shortest, delay)
    poll_longest = max(poll_longest, delay)
    poll_last_time = now
    sched_cause(0.002, nil, 'poll_callback')
    

// handler for cdcheckbox: start/stop analysis
def collect_data(x):
    display "collect_data", x
    yin_start(x)
    if not SAVE_DATA:
        return
    onset_start(x)
    spectralcentroid_start(x)
    spectralrolloff_start(x)
    if x:
        // DEBUG
        // start_poll_test()

        if not data_file:
            data_file_name = "perfdata" + leftpad(data_file_id, 3, "0") + ".csv"
            data_file = open(data_file_name, "r")
            while data_file:
                data_file.close()
                data_file_id = data_file_id + 1
                data_file_name = "perfdata" + leftpad(data_file_id, 3, "0") +
                                 ".csv"
                data_file = open(data_file_name, "r")
            # now, data_file_name does not already exist, so safe to write
            data_file = open(data_file_name, "w")
    else:
        // DEBUG
        // display "poll test", poll_shortest, poll_longest, poll_count
        // display "         ", poll_short_count, poll_long_count

        data_file.close()
        data_file = nil
        print "------------------------------"
        print "Wrote", data_file_name
        print "------------------------------"


