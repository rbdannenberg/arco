def actl_yin(timestamp, address, types, pitch, harmonicity, rms)
    var text = ""
    if harmonicity < 0.1 and rms > 0.01:
        text = float_places(pitch, 1)
    yintext.set_string(text)
    save_data("yin", pitch, harmonicity, rms)
    // display "actl_yin", timestamp, sched_time_get() - timestamp
    note_transcriber.yin_input(pitch, harmonicity, rms)
        

yin_handler_installed = false
YIN_SAMPLE_RATE = 50  // should divide into 44100 evenly
YIN_PERIOD = 1.0 / YIN_SAMPLE_RATE
YIN_PERIOD_INCR = YIN_PERIOD * 0.95  // for estimating yin input time

// handler for yincheckbox: play/stop yin analysis of input
def yin_start(x):
    display "yintest", x
    if x:
        if not yin_handler_installed:
            o2_method_new("/actl/yin", "fff", 'actl_yin', t)
            print "installed yin handler"
            yin_handler_installed = true
        yininp = input_ugen
        yin = yin(yininp, PITCH_LOW, PITCH_HIGH, idiv(44100, YIN_SAMPLE_RATE),
                  "/actl/yin")
        yin.run()
    else:
        yin.unrun()
        yin = nil
        yininp = nil


