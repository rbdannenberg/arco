// ==== INFERENCE AND PLAY NEW PHRASE ====

poly_count = 0
first_phrase_time = nil
active_since = 0
take_the_lead = false
lay_out = false
lay_out_ended = 0
lay_out_until = 0

# Laying out - we have a mechanism for stopping synthesis and letting
# the trumpet solo with lots of reverb and effects still enabled.
# STARTING - we record the time when all synthesis output stops, called
# tacet_since. This indicates that the trumpet is not playing much either,
# although it could have just been waiting for things to calm down and
# might be playing as soon as synthesis stops. So we can also record the
# last time the trumpet played, calling it rest_start. We will poll every
# second (in compute_activity()) for the condition:
#    sched_rtime > tacet_since + 1 and sched_rtime > rest_start + 1
# which can become true in 1 to 2 seconds (due to polling rate) after there
# is no playing at all. We restrict this further in 2 ways:
# 1. only act if not lay_out, so avoid extending the already started mode
# 2. only act if we have not started lay_out for at least 60 sec
# STOPPING - lay_out will run for 15 to 30 sec, but we want to EXTEND the
# mode as long as the player wants to take advantage of the space using
# isolated playing and letting the reverb ring. So, we only end lay_out
# if the initial timeout has occurred AND the trumpet played without a 1 sec
# rest for at least 2 sec. For this we need active_since to be updated in
# Run_length_process as it processes YIN input.


 

def compute_activity():
# called every 1 sec by tempoctrl.compute_tempo to notice
# pauses in playing: If no pause in 60 sec, we want to
# lay out for 15 to 25 sec.  A pause is 3 sec.
# If there's a pause for 15 sec, we should take the lead
# until trumpet plays again.
    if run_length_process.rest_dur > 3:
        active_since = sched_rtime

    // take_the_lead does not actually do anything now
    if run_length_process.rest_dur > 15:
        if not take_the_lead:
            display "MODE", take_the_lead, sched_rtime
        take_the_lead = true
    if take_the_lead and run_length_process.rest_dur < 1:
        if take_the_lead:
            display "MODE", take_the_lead, sched_rtime
        take_the_lead = false
    // lay_out computation
    if sched_rtime > tacet_since + 1 and not poly_enable and
       sched_rtime > run_length_process.rest_dur + 1 and
       not lay_out and
       sched_rtime > max(run_length_process.start_time, lay_out_ended) + 60:
        lay_out = true
        lay_out_until = sched_rtime + pr_unif(15, 30)
        labellog_label("lay_out begin")
        fxrevbrt60.set_and_act(12)
        fxdlygain.set_and_act(0.2)
        effects.delay_ugen.set('dur', 0.2)
        effects.delay_ugen.set('fb', 0.4)
        print "lay_out begin"
    if lay_out and sched_rtime > lay_out_until and
       sched_rtime > run_length_process.active_since + 2:
        lay_out = false
        lay_out_ended = sched_rtime
        labellog_label("lay_out end")
        print "lay_out end"
        // let auto() change reverb on the next gap


//  old version:
//    if sched_rtime - active_since > 60 and not lay_out:
//        lay_out_until = sched_rtime + pr_unif(15, 25)
//        lay_out = true
//        display "MODE", lay_out, sched_rtime
//    if lay_out and sched_rtime > lay_out_until:
//        lay_out = false
//        display "MODE", lay_out, sched_rtime


def time_since_last_pause():
    sched_rtime - most_recent_phrase_time


def send_to_vae(phrase):
    if not first_phrase_time:
        first_phrase_time = sched_rtime
    most_recent_phrase_time = sched_rtime

    o2_send_start()
    for p at i in phrase:
        // convert nil to -1
        o2_add_int32(p or -1)
    o2_send_finish(0.0, "/vae/run", true)


def vae_process(phrase, short):
# use o2inference (via O2) to transform input, which is
# an array of pitches with nil for rest
#
# To interpret results properly, keep poly_count: 
# increment for each vae_process used for poly_enable.
# actl_phrase will decrement the count. Iff the count
# is zero, handle the return phrase by playing it in
# time as mono.
    // send data as integers to vae/run
    vae_phrase_is_short = short
    if poly_enable and not phrases_playing:
        // get 16 variants
        for i = 0 to 16:
            poly_count = poly_count + 1
            send_to_vae(phrase)
            // disable more poly in 1 sec and re-enable when phrase_player
            // finishes playing all resulting phrases
            sched_select(rtsched)
            sched_cause(1, nil, 'disable_poly')
    elif echo_enable:  // play VAE phrases normally (subject to lay_out)
        vae_process_start = rtsched.time
        send_to_vae(phrase)
        print "vae_process", phrase2str(phrase)
    

phrases_playing = false
def disable_poly():
    phrases_playing = true



def actl_phrase(timestamp, address, types, pitches):
    var phrase = string_split(pitches, " ")
    phrase = [int(p) for p in phrase]
    if vae_phrase_is_short:
        phrase.set_len(16)
    if poly_count == 0:
        var inference_time = rtsched.time - vae_process_start
        display "INFERENCE COMPLETE", inference_time
        phrase_player.start(phrase)
        // play same phrase delayed by 8 beats and transposed down
        sched_cause(8, phrase_player, 'start', phrase, LEAD2_CHAN, -12)
    else:
        print "POLY:", phrase2str(phrase)
        var transpose = -12 if poly_count >= 11 else
                        (0 if poly_count >= 5 else 12)
        var delay = max(0, 4 - poly_count * 0.25) // shorter ones get delayed
        sched_select(rtsched)
        var stretch = 1 + poly_count * 0.2
        if dbltim_enable:
            stretch = stretch * 0.5
        // use channels 2 through 9 (represented as 1 through 8)
        // (channel 10 is drums, channel 11 is chords), with is_poly = true
        sched_cause(delay, phrase_player, 'start', phrase,
                    poly_count % 8 + 1, transpose, stretch, true)
        if boost_enable:
            transpose = 12
            sched_cause(delay + 4, phrase_player, 'start', phrase,
                        (poly_count + 2) % 8 + 1, transpose, stretch, true)
            transpose = -24
//            if transpose > 24:
//                transpose = -12
            sched_cause(delay + 3, phrase_player, 'start', phrase,
                        (poly_count + 2) % 8 + 1, transpose, stretch, true)
            
            
        poly_count = poly_count - 1


def style_init():
# set up for style classification
    var left = wxs_x
    wxs_y = wxs_y + 10
    style_guages = []
    style_labels = []
    for sname at i in STYLE_NAMES:
        style_labels.append(Statictext(default_window, sname,
                                       'S', wxs_y + 15, 60, 'H'))
        var g = Gauge(default_window, 1000, 'R', wxs_y - 4, 100, 'H')
        style_guages.append(g)
        wxs_x = left
    style_start_poll()


def solo_boxes_init():
    var win = default_window
    var left = wxs_x
    Checkbox(win, "lead", 'S', 'D', 55, 'H', 'leadsolocheckbox')
    leadsolocheckbox.set_and_act(true)
    Checkbox(win, "lead2", 'R', 'S', 60, 'H', 'lead2solocheckbox')
    lead2solocheckbox.set_and_act(true)
    Checkbox(win, "chord", 'R', 'S', 60, 'H', 'chordsolocheckbox')
    chordsolocheckbox.set_and_act(true)
    Checkbox(win, "drums", 'R', 'S', 60, 'H', 'drumsolocheckbox')
    drumsolocheckbox.set_and_act(true)
    wxs_x = left  // restore left margin for other controls
    Checkbox(win, "tpt", 'S', 'D', 50, 'H', 'tptsolocheckbox')
    tptsolocheckbox.add_callback('tptsolo_handler', 'x')
    tptsolocheckbox.set_and_act(true)

    
def tptsolo_handler(x):
    master_fx_ugen.set(1 if x else 0)


def main():
    o2_debug_flags("") // ("SsBl")
    var files = ["trumpet.wav", "descend.wav", "fast.wav", "slow.wav"]
    arco_set_input_files(["/Users/rbd/algocomp/rbd25/audio/" + file
                          for file in files])
    arco_init(ensemble = "rbdperfdata", latency = 10, network = false,
              title = "Tpt", appname = "tpt", ins = 1)
    o2lite_initialize()
    arco_run()
    sched_select(rtsched)

    var file_menu = default_window.get_menu("File")
    file_menu.item("Print Ugen Info", "print Ugen tree and table",
                   nil, nil, 'arco_prugens_handler')
    file_menu.item("Arco Ugen GC Info", "print info about Ugen IDs",
                   nil, nil, 'arco_ugen_gc_info_handler')

main()
