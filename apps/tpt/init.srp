def every_16th():
# action invoked by Tempo_control every 16th note period
    note_transcriber.poll()  // update pitch and duration fields
    var phase = round(sched_vtime * 4) % 32
    phrase_maker.poll(phase)  // accumulate pitches into phrase
    style_estimation.poll()   // accumulate pitches into windows
    tempo_control.compute_tempo(phase)
    drummer.play_drums(phase)
    plot_notes.every_16th(phase)


