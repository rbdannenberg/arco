    flsyn_mix.ins("chord", gran_ugen, [flchdsyn_gain, flchdsyn_gain])

    zrev_ugen = zitarev(flsyn_mix, 0.5, 0.5, 1.0)
    highpass_ugen = highpass(zrev_ugen, 20.0)  // remove "DC"
    highpass_ugen.play()
    flsyn_ugen.program_change(0, 0)

    Checkbox(win, "drums", 'S', 25, 60, 20, 'drumscheckbox')
    drumscheckbox.add_callback('drums_enable_handler', 'x')
    drumscheckbox.set_and_act(true)

    wxs_space = -2  // tight spacing

    Checkbox(win, "hold", 'S', 'D', 60, 'S', 'holdcheckbox')
    holdcheckbox.add_callback('hold_enable_handler', 'x')

    Checkbox(win, "dense", 'S', 'D', 60, 'S', 'densecheckbox')
    densecheckbox.add_callback('dense_fill_handler', 'x')

    Checkbox(win, "echo", 'S', 'D', 60, 'S', 'echocheckbox')
