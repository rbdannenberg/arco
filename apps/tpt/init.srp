    ready_count = ready_count + 1
    if ready_count > 1:
        display "arco_ready called again", ready_count
        breakpoint()
    var win = default_window
    if ui_initialized:
        return

    display "arco_ready", wxs_h, wxs_space,

    o2_method_new("/actl/phrase", "s", 'actl_phrase', t)
    // see stylectrl.srp for actl_style() definition:
    o2_method_new("/actl/style", "fff", 'actl_style', t)

    display WXS_DEFAULT_HEIGHT, WXS_DEFAULT_SPACE
    var WIDTH = 170
    Checkbox(win, "Collect Data", 5, 5, 100, 20, 'cdcheckbox')
    cdcheckbox.add_callback('collect_data', 'x')
    cdcheckbox.set_and_act(true)
    var top_y = wxs_y
    Statictext(win, "", 'R', top_y + 2, 25, wxs_h - 2, 'yintext')
    Checkbox(win, "Auto", 'R', top_y, 55, 20, 'auto_cb')
    auto_cb.set_value(true)
    Checkbox(win, "Replay", 'R', 5, 70, 20, 'replaycheckbox')
    replaycheckbox.add_callback('replay_handler', 'x')
    replaycheckbox.set_and_act(false)
    Statictext(win, "", 'R', wxs_y + 2, 60, 'S', 'tempotext')
    display "tempotext", tempotext.get_left(), tempotext.get_top()

    Plot_notes(default_window, 5, 210, 400, 450, 'plot_notes')
    note_transcriber = Notes()
    phrase_maker = Phrase_maker()
    style_estimation = Style_estimation()
    Tempo_control()  // starts a Periodic assigned to 'tempo_control'
    // Tempo_control calls 'every_16th' every 16th
    phrase_player = Phrase_player()
    drummer = Drummer()

    var flsyn_gain = 20.0
    var flchdsyn_gain = 24.0 // 16.0 was ok, trying louder still
                // 10 was low, 16 is based on how low 10 sounded
    flsyn_ugen = Flsyn(SOUNDFONT)
    display "in arco_ready", flsyn_ugen
    // flsyn_chorus_ugen = chorusrbd(flsyn_ugen, 0.02, 0.04,
    // 0.02, 0.4, 0.02, 0.6,
    // 0.2, 0.7, 0.5)
    flsyn_chorus_ugen = flsyn_ugen
    flsyn_mix = mix(2)
    flsyn_mix.ins("nonchd", flsyn_chorus_ugen, [flsyn_gain, flsyn_gain])
    
    flchdsyn_ugen = Flsyn(SOUNDFONT)
